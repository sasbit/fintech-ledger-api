# Database Configuration
MONGODB_URI=mongodb://localhost:27017/simple-ledger
MONGODB_DB_NAME=simple-ledger

# Application Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json

# Swagger Configuration
SWAGGER_TITLE=Simple Ledger API
SWAGGER_DESCRIPTION=A simplified double-entry ledger API with hash chaining
SWAGGER_VERSION=1.0.0
