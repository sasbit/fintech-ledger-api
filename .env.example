# DB config
MONGODB_URI=mongodb://localhost:27017/ledger
MONGODB_DB_NAME=ledger

# Application config
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Logging config
LOG_LEVEL=debug
LOG_FORMAT=json

# Swagger config
SWAGGER_TITLE=Ledger API
SWAGGER_DESCRIPTION=Double-entry ledger API with hash chaining
SWAGGER_VERSION=1.0.0
